{
  "name": "shader-lab",
  "description": "Shader Lab starter template",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.5",
  "scripts": {
    "analyze": "cross-env ANALYZE=true bun run build",
    "analyze:experimental": "next experimental-analyze",
    "build": "bun run setup:styles && next build",
    "dev": "bun ./src/scripts/dev.ts",
    "dev:https": "bun ./src/scripts/dev.ts --https",
    "dev:inspect": "bun ./src/scripts/dev.ts --inspect",
    "format": "biome format --write .",
    "generate": "bun ./src/scripts/generate.ts",
    "lighthouse": "bunx @unlighthouse/cli --site http://localhost:3000",
    "lint": "biome lint --max-diagnostics=200",
    "lint:fix": "biome lint --write --unsafe --max-diagnostics=200",
    "setup:styles": "bun ./src/shared/styles/scripts/setup-styles.ts",
    "start": "next start",
    "test": "bun test",
    "typecheck": "tsgo --noEmit",
    "typecheck:compare": "bun run typecheck:tsc && bun run typecheck",
    "typecheck:tsc": "tsc --noEmit --incremental false"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@phosphor-icons/react": "^2.1.10",
    "class-variance-authority": "^0.7.1",
    "motion": "^12.38.0",
    "next": "16.1.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-use": "^17.6.0",
    "tailwind-merge": "^3.4.0",
    "three": "^0.183.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@clack/prompts": "^0.11.0",
    "@csstools/postcss-global-data": "^3.1.0",
    "@next/bundle-analyzer": "16.1.1",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/bun": "^1.3.6",
    "@types/node": "^20.19.30",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@typescript/native-preview": "^7.0.0-dev.20260122.3",
    "babel-plugin-react-compiler": "1.0.0",
    "cross-env": "^10.1.0",
    "postcss-functions": "^4.0.2",
    "postcss-preset-env": "^10.6.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "@tailwindcss/oxide",
    "esbuild",
    "sharp"
  ]
}
